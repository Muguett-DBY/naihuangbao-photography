{
  "name": "portrait-booking-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "avif": "node scripts/convert-to-avif.mjs",
    "build": "npm run avif && tsc -b && vite build",
    "build:full": "npm run seo:sync && npm run avif && tsc -b && vite build && npm run perf:budget",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "tsc -b --noEmit",
    "test": "vitest run",
    "cf:types": "wrangler types worker-configuration.d.ts",
    "seo:sync": "node --import tsx/esm scripts/sync-seo-shell.mjs",
    "perf:budget": "node scripts/check-performance-budget.mjs",
    "assets:crop": "node --import tsx/esm scripts/crop-gallery-assets.mjs"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/nunito": "^5.2.7",
    "animal-island-ui": "^0.9.4",
    "face-api.js": "^0.22.2",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "i18next": "^26.3.0",
    "leaflet": "^1.9.4",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "photoswipe": "^5.4.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.16.0",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260529.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  }
}
