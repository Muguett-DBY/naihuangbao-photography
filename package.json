{
  "name": "portrait-booking-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "avif": "node scripts/convert-to-avif.mjs",
    "build": "npm run avif && tsc -b && vite build",
    "build:full": "npm run seo:sync && npm run sitemap:build && npm run avif && tsc -b && vite build && npm run perf:budget && npm run bundle:analyze",
    "preview": "vite preview --host 0.0.0.0",
    "sitemap:build": "node --import tsx/esm scripts/build-sitemap.ts",
    "bundle:analyze": "node scripts/analyze-bundle.mjs",
    "lint": "tsc -b --noEmit",
    "test": "vitest run",
    "cf:types": "wrangler types worker-configuration.d.ts",
    "seo:sync": "node --import tsx/esm scripts/sync-seo-shell.mjs",
    "perf:budget": "node scripts/check-performance-budget.mjs",
    "assets:crop": "node scripts/crop-gallery-assets.mjs"
  },
  "dependencies": {
    "@fontsource/nunito": "^5.2.7",
    "animal-island-ui": "^1.2.1",
    "face-api.js": "^0.22.2",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "i18next": "^26.3.6",
    "leaflet": "^1.9.4",
    "lenis": "^1.3.25",
    "lucide-react": "^1.24.0",
    "photoswipe": "^5.4.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.18.1",
    "swiper": "^14.0.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@playwright/test": "^1.61.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "@tensorflow/tfjs-core": {
      "node-fetch": "2.6.7"
    }
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "workerd@1.20260708.1": true
  }
}
